      <aliases enabled='yes' />
      <column caption='Profit Ratio' datatype='real' name='[Calculation_0600401122828288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit] / [Sales]' />
      </column>
      <column caption='Sales Category' datatype='string' name='[Calculation_0600401123651585]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 30000 THEN &quot;High Sales&quot;&#13;&#10;ELSEIF [Sales] &gt;10000 THEN &quot;Medium Sales&quot;&#13;&#10;ELSE &quot;Low Sales&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Category' datatype='string' name='[Calculation_0600401125617666]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &gt; 5000 THEN &quot;Good Profit&quot;&#13;&#10;else &quot;Low Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='UpperCase Customer Name' datatype='string' name='[Calculation_0600401127931907]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER([CustomerName])' />
      </column>
      <column caption='Customer+Region' datatype='string' name='[Calculation_0600401128849412]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[CustomerName]+ &quot;-&quot; +[Region]' />
      </column>
      <column caption='Average Sales' datatype='real' name='[Calculation_0600401130651653]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Sales])' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_0600401133154310]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Percentage of Total' datatype='real' name='[Calculation_0600401133563911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/TOTAL(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Logical AND' datatype='string' name='[Calculation_0600401134452744]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Sales] &gt; 10000 AND [Profit]&gt; 2000 THEN &quot;Excellent&quot;&#13;&#10;ELSE &quot;Average&quot;&#13;&#10;END' />
      </column>
      <column caption='Case Statement' datatype='string' name='[Calculation_0600401135964170]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Region]&#13;&#10;WHEN &quot;West&quot; THEN &quot;W&quot;&#13;&#10;WHEN &quot;East&quot; THEN &quot;E&quot;&#13;&#10;WHEN  &quot;North&quot; THEN &quot;N&quot;&#13;&#10;ELSE &quot;S&quot;&#13;&#10;END' />
      </column>
